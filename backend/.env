# ─────────────────────────────────────────────────────────
#  SiteForge — Backend Environment Variables
#  COPY this file to ".env":   cp .env.example .env
#  NO MySQL required — MongoDB only!
# ─────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# JWT — change this to any long random string in production
JWT_SECRET=siteforge_super_secret_jwt_key_change_me_32chars
JWT_EXPIRE=7d

# ─── MongoDB (only database needed) ──────────────────────
# Option A: Local MongoDB (default)
MONGODB_URI=mongodb://localhost:27017/ai_website_builder

# Option B: MongoDB Atlas (cloud, free tier available)
# Sign up at https://cloud.mongodb.com, create a cluster,
# then replace the line above with your Atlas SRV string:
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/ai_website_builder

# ─── Frontend URL (CORS) ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── File Upload ─────────────────────────────────────────
MAX_FILE_SIZE=5242880
